module CNC_ETCHING_MACHINE (
  clk,
  sclk,
  mosi,
  miso,
  cs_n,
  ready_pin,
  step_x,
  step_y,
  step_z,
  dir_x,
  dir_y,
  dir_z,
  spindle_pwm,
  limit_x,
  limit_y,
  limit_z
)
;
input clk;
input sclk;
input mosi;
output miso;
input cs_n;
output ready_pin;
output step_x;
output step_y;
output step_z;
output dir_x;
output dir_y;
output dir_z;
output spindle_pwm;
input limit_x;
input limit_y;
input limit_z;
wire clk_d;
wire sclk_d;
wire mosi_d;
wire cs_n_d;
wire limit_x_d;
wire limit_y_d;
wire limit_z_d;
wire raw_opcode_2_9;
wire ready_pin_15;
wire packet_done;
wire miso_reg;
wire move_done_prev;
wire n14_16;
wire instruction_ready_Z;
wire kill_flag_Z;
wire is_motion_Z;
wire homing_reset_Z;
wire spindle_on_sig;
wire pause_flag_Z;
wire step_x_d;
wire step_y_d;
wire step_z_d;
wire move_finished_Z;
wire dir_x_d;
wire dir_y_d;
wire dir_z_d;
wire in_kill_mode;
wire spindle_pwm_d;
wire [143:8] shift_rx_Z;
wire [3:3] fifo_count_Z;
wire [143:8] act_instr;
wire [31:0] target_x;
wire [31:0] target_y;
wire [31:0] target_z;
wire [15:0] spindle_speed_sig;
wire [31:0] current_x_Z;
wire [31:0] current_y_Z;
wire [31:0] current_z_Z;
wire VCC;
wire GND;
  IBUF clk_ibuf (
    .O(clk_d),
    .I(clk) 
);
  IBUF sclk_ibuf (
    .O(sclk_d),
    .I(sclk) 
);
  IBUF mosi_ibuf (
    .O(mosi_d),
    .I(mosi) 
);
  IBUF cs_n_ibuf (
    .O(cs_n_d),
    .I(cs_n) 
);
  IBUF limit_x_ibuf (
    .O(limit_x_d),
    .I(limit_x) 
);
  IBUF limit_y_ibuf (
    .O(limit_y_d),
    .I(limit_y) 
);
  IBUF limit_z_ibuf (
    .O(limit_z_d),
    .I(limit_z) 
);
  TBUF miso_s1 (
    .O(miso),
    .I(miso_reg),
    .OEN(cs_n_d) 
);
  OBUF ready_pin_obuf (
    .O(ready_pin),
    .I(ready_pin_15) 
);
  OBUF step_x_obuf (
    .O(step_x),
    .I(step_x_d) 
);
  OBUF step_y_obuf (
    .O(step_y),
    .I(step_y_d) 
);
  OBUF step_z_obuf (
    .O(step_z),
    .I(step_z_d) 
);
  OBUF dir_x_obuf (
    .O(dir_x),
    .I(dir_x_d) 
);
  OBUF dir_y_obuf (
    .O(dir_y),
    .I(dir_y_d) 
);
  OBUF dir_z_obuf (
    .O(dir_z),
    .I(dir_z_d) 
);
  OBUF spindle_pwm_obuf (
    .O(spindle_pwm),
    .I(spindle_pwm_d) 
);
  LUT4 raw_opcode_2_s3 (
    .F(raw_opcode_2_9),
    .I0(act_instr[123]),
    .I1(act_instr[122]),
    .I2(n14_16),
    .I3(spindle_on_sig) 
);
defparam raw_opcode_2_s3.INIT=16'hDFC0;
  INV ready_pin_s13 (
    .O(ready_pin_15),
    .I(fifo_count_Z[3]) 
);
  SPI_Interface SPI_Unit (
    .sclk_d(sclk_d),
    .cs_n_d(cs_n_d),
    .mosi_d(mosi_d),
    .n14_16(n14_16),
    .current_x_Z(current_x_Z[31:0]),
    .current_y_Z(current_y_Z[31:0]),
    .current_z_Z(current_z_Z[31:0]),
    .act_instr(act_instr[143:128]),
    .packet_done(packet_done),
    .miso_reg(miso_reg),
    .shift_rx_Z(shift_rx_Z[143:8])
);
  Instruction_FIFO FIFO_Unit (
    .packet_done(packet_done),
    .clk_d(clk_d),
    .in_kill_mode(in_kill_mode),
    .move_finished_Z(move_finished_Z),
    .shift_rx_Z(shift_rx_Z[143:8]),
    .move_done_prev(move_done_prev),
    .n14_16(n14_16),
    .fifo_count_Z(fifo_count_Z[3]),
    .act_instr(act_instr[143:8])
);
  Opcode_Decoder The_Decoder (
    .clk_d(clk_d),
    .n14_16(n14_16),
    .move_finished_Z(move_finished_Z),
    .move_done_prev(move_done_prev),
    .raw_opcode_2_9(raw_opcode_2_9),
    .act_instr(act_instr[127:8]),
    .current_x_Z(current_x_Z[31:0]),
    .current_y_Z(current_y_Z[31:0]),
    .current_z_Z(current_z_Z[31:0]),
    .instruction_ready_Z(instruction_ready_Z),
    .kill_flag_Z(kill_flag_Z),
    .is_motion_Z(is_motion_Z),
    .homing_reset_Z(homing_reset_Z),
    .spindle_on_sig(spindle_on_sig),
    .pause_flag_Z(pause_flag_Z),
    .target_x(target_x[31:0]),
    .target_y(target_y[31:0]),
    .target_z(target_z[31:0]),
    .spindle_speed_sig(spindle_speed_sig[15:0])
);
  Step_Generator Motor_Driver (
    .clk_d(clk_d),
    .kill_flag_Z(kill_flag_Z),
    .pause_flag_Z(pause_flag_Z),
    .is_motion_Z(is_motion_Z),
    .instruction_ready_Z(instruction_ready_Z),
    .homing_reset_Z(homing_reset_Z),
    .limit_x_d(limit_x_d),
    .limit_y_d(limit_y_d),
    .limit_z_d(limit_z_d),
    .target_x(target_x[31:0]),
    .target_y(target_y[31:0]),
    .target_z(target_z[31:0]),
    .step_x_d(step_x_d),
    .step_y_d(step_y_d),
    .step_z_d(step_z_d),
    .move_finished_Z(move_finished_Z),
    .dir_x_d(dir_x_d),
    .dir_y_d(dir_y_d),
    .dir_z_d(dir_z_d),
    .in_kill_mode(in_kill_mode),
    .current_x_Z(current_x_Z[31:0]),
    .current_y_Z(current_y_Z[31:0]),
    .current_z_Z(current_z_Z[31:0])
);
  Spindle_PWM Spindle_Driver (
    .clk_d(clk_d),
    .kill_flag_Z(kill_flag_Z),
    .spindle_on_sig(spindle_on_sig),
    .spindle_speed_sig(spindle_speed_sig[15:0]),
    .spindle_pwm_d(spindle_pwm_d)
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* CNC_ETCHING_MACHINE */
